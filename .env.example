# Порт API-сервера
API_PORT=3001

# Токен простой авторизации API (один пользователь).
# Если не задан — авторизация выключена (локальный режим).
API_TOKEN=

# Google Calendar (OAuth2). Создать в Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3001/api/gcal/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/gcal/callback
