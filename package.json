{
  "name": "task-trek",
  "version": "0.1.0",
  "private": true,
  "description": "Трекер задач «Внешний мозг»",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
